<?xml version="1.0" encoding="UTF-8"?>

<mule xmlns:http="http://www.mulesoft.org/schema/mule/http"
      xmlns="http://www.mulesoft.org/schema/mule/core"
      xmlns:doc="http://www.mulesoft.org/schema/mule/documentation"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="
      http://www.mulesoft.org/schema/mule/core http://www.mulesoft.org/schema/mule/core/current/mule.xsd
      http://www.mulesoft.org/schema/mule/http http://www.mulesoft.org/schema/mule/http/current/mule-http.xsd">

   
    <flow name="get-users-impl">

        <try doc:name="Try" doc:id="7824771e-28dd-408b-a56a-6051823aaf8f" >
			<http:request config-ref="external-api-config" method="GET" path="${external.api.usersEndpoint}" />
			<error-handler ref="global-error-handler" />
		</try>

    </flow>

    
    <flow name="get-posts-impl">

        <try doc:name="Try" doc:id="b1fa8e61-11a0-48d4-baad-bb6aa1885acf" >
			<http:request config-ref="external-api-config" method="GET" path="${external.api.postsEndpoint}" />
			<error-handler ref="global-error-handler" />
		</try>

    </flow>

</mule>